-- SWITCH UI (mais compacto)
function createSwitch(text, y, callback)
	local holder = Instance.new("Frame", frame)
	holder.Size = UDim2.new(0.9,0,0,30)
	holder.Position = UDim2.new(0.05,0,0,y)
	holder.BackgroundTransparency = 1
	
	local label = Instance.new("TextLabel", holder)
	label.Size = UDim2.new(0.6,0,1,0)
	label.Text = text
	label.TextColor3 = Color3.new(0,0,0)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.TextXAlignment = Enum.TextXAlignment.Left
	
	local toggle = Instance.new("Frame", holder)
	toggle.Size = UDim2.new(0,42,0,20)
	toggle.Position = UDim2.new(0.75,0,0.5,-10)
	toggle.BackgroundColor3 = Color3.fromRGB(200,200,200)
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(1,0)
	
	local circle = Instance.new("Frame", toggle)
	circle.Size = UDim2.new(0,16,0,16)
	circle.Position = UDim2.new(0,2,0.5,-8)
	circle.BackgroundColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", circle).CornerRadius = UDim.new(1,0)
	
	local enabled = false
	
	toggle.InputBegan:Connect(function()
		enabled = not enabled
		
		if enabled then
			toggle.BackgroundColor3 = Color3.fromRGB(0,170,255)
			circle:TweenPosition(UDim2.new(1,-18,0.5,-8),"Out","Quad",0.2,true)
		else
			toggle.BackgroundColor3 = Color3.fromRGB(200,200,200)
			circle:TweenPosition(UDim2.new(0,2,0.5,-8),"Out","Quad",0.2,true)
		end
		
		callback(enabled)
	end)
end

-- POSIÇÕES MAIS JUNTAS (SEM BURACO)
createSwitch("Remove Animation",35,function(state)
	if state then
		task.spawn(function()
			while state do
				local char = player.Character
				if char and char:FindFirstChild("Humanoid") then
					for _,v in pairs(char.Humanoid:GetPlayingAnimationTracks()) do
						v:Stop()
					end
				end
				task.wait(0.2)
			end
		end)
	end
end)

createSwitch("PvP Camera",70,function(state)
	pvpOn = state
	
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	if state then
		workspace.CurrentCamera.FieldOfView = 100
		startPos = hrp.Position
		
		line = Instance.new("Part", workspace)
		line.Anchored = true
		line.CanCollide = false
		line.Color = Color3.new(0,1,0)
		line.Material = Enum.Material.Neon
	else
		workspace.CurrentCamera.FieldOfView = 70
		if line then line:Destroy() end
	end
	
	if state then
		task.spawn(function()
			while pvpOn and line do
				local dist = (startPos - hrp.Position).Magnitude
				line.Size = Vector3.new(0.2,0.2,dist)
				line.CFrame = CFrame.new(startPos, hrp.Position) * CFrame.new(0,0,-dist/2)
				task.wait()
			end
		end)
	end
end)

createSwitch("Infinite Jump",105,function(state)
	infJumpOn = state
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
	if infJumpOn then
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			char.HumanoidRootPart.Velocity = Vector3.new(0,45,0)
		end
	end
end)

createSwitch("Auto Attack",140,function(state)
	autoAttackOn = state
	
	if state then
		task.spawn(function()
			while autoAttackOn do
				local char = player.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					local hrp = char.HumanoidRootPart
					
					local closest
					local dist = math.huge
					
					for _,p in pairs(game.Players:GetPlayers()) do
						if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
							local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
							if d < dist then
								dist = d
								closest = p
							end
						end
					end
					
					if closest then
						local target = closest.Character.HumanoidRootPart.Position
						hrp.CFrame = hrp.CFrame:Lerp(
							CFrame.new(target + Vector3.new(0,0,2)),
							0.25
						)
					end
				end
				task.wait(0.08)
			end
		end)
	end
end)

createSwitch("Auto Pickup",175,function(state)
	autoPickupOn = state
	
	if state then
		task.spawn(function()
			while autoPickupOn do
				local char = player.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					local hrp = char.HumanoidRootPart
					
					for _,prompt in pairs(workspace:GetDescendants()) do
						if prompt:IsA("ProximityPrompt") then
							prompt.HoldDuration = 0
							
							local parent = prompt.Parent
							local part = parent and (parent:IsA("BasePart") and parent or parent:FindFirstChildWhichIsA("BasePart"))
							
							if part then
								local dist = (part.Position - hrp.Position).Magnitude
								
								if dist <= prompt.MaxActivationDistance then
									pcall(function()
										fireproximityprompt(prompt)
									end)
								end
							end
						end
					end
				end
				task.wait(0.15)
			end
		end)
	end
end)

